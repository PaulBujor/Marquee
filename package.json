{
	"name": "marquee",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types && vite build",
		"preview": "wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"gen:icons": "node scripts/generate-icons.mjs",
		"test": "svelte-kit sync && vitest run",
		"test:watch": "svelte-kit sync && vitest",
		"test:coverage": "svelte-kit sync && vitest run --coverage",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply marquee --local",
		"db:migrate:remote": "wrangler d1 migrations apply marquee --remote",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.25.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^26",
		"@types/nodemailer": "^8.0.1",
		"@vitest/coverage-v8": "^4.1.10",
		"better-sqlite3": "^12.11.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.7.0",
		"nodemailer": "^9.0.3",
		"png-to-ico": "^3.0.2",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.3",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"wrangler": "^4.111.0"
	},
	"dependencies": {
		"bits-ui": "^2.18.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"idb": "^8.0.3",
		"resend": "^6.17.2",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	}
}
